# Secrets — never commit (see HANDOFF.md § Security)
# NOTE: .gitignore does NOT support trailing inline comments — keep comments
# on their own lines, or the pattern silently includes the comment text.
.env
.env.*
# ...but DO commit the no-secrets template:
!.env.example
# Telethon auth artifacts (live credentials):
*.session
*.session-journal

# Live config — contains your real channel/chat IDs. Copy from the tracked
# *.toml.example templates and edit locally (same pattern as .env / .env.example).
config/sources.toml
config/briefings.toml

# Generated briefs (text + audio)
briefs/

# SQLite store (brief history + run-state)
data/

# Rotating run log + failure markers (observability; see ROADMAP ISSUE-3)
logs/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

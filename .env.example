# Copy to .env and fill in. .env is gitignored — NEVER commit real values.
# Config files reference these by NAME via `credentials_ref`, never by value.
# See HANDOFF.md § Security.
#
# IMPORTANT: keep comments on their OWN lines. A trailing "# ..." after a
# value is read as PART of the value by python-dotenv (empty vars especially).

# Discord user token — FULL account access if leaked. Most sensitive secret here.
DISCORD_USER_TOKEN=

# Telegram (Telethon userbot). TELEGRAM_SESSION is the session name; the
# resulting *.session file is gitignored.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=briefing

# Synthesis (required)
ANTHROPIC_API_KEY=

# TTS — OpenAI (echo voice, plain). Required if you want the spoken audio brief;
# text-only briefs don't need it.
OPENAI_API_KEY=

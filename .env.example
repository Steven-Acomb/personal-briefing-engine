# Copy to .env and fill in. .env is gitignored — NEVER commit real values.
# Config files reference these by NAME via `credentials_ref`, never by value.
# See HANDOFF.md § Security.
#
# IMPORTANT: keep comments on their OWN lines. A trailing "# ..." after a
# value is read as PART of the value by python-dotenv (empty vars especially).

# Discord user token — FULL account access if leaked. Most sensitive secret here.
DISCORD_USER_TOKEN=

# Telegram (Telethon userbot). TELEGRAM_SESSION is the session name; the
# resulting *.session file is gitignored.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=briefing

# Synthesis (required)
ANTHROPIC_API_KEY=

# TTS — primary backend: ElevenLabs (natural voices). Get a key at elevenlabs.io
# (free trial tier available). Pick a voice in their library and put its id in
# ELEVENLABS_VOICE_ID; browse models for ELEVENLABS_MODEL (eleven_multilingual_v2
# = stable quality, eleven_v3 = most expressive).
ELEVENLABS_API_KEY=
# Optional — blank defaults to "Brian" (warm male narrator):
ELEVENLABS_VOICE_ID=
# Optional — blank defaults to eleven_multilingual_v2:
ELEVENLABS_MODEL=

# TTS — fallback backend: OpenAI (echo voice, plain). Used when no ElevenLabs
# key is set. Only needed if you want the fallback to work.
OPENAI_API_KEY=

# Copy to .env and fill in. .env is gitignored — NEVER commit real values.
# Config files reference these by NAME via `credentials_ref`, never by value.
# See HANDOFF.md § Security.

# Discord user token — FULL account access if leaked. Most sensitive secret here.
DISCORD_USER_TOKEN=

# Telegram (Telethon userbot)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=briefing        # session name; the *.session file is gitignored

# Synthesis
ANTHROPIC_API_KEY=

# TTS — primary backend: ElevenLabs (natural voices). Get a key at
# elevenlabs.io (free trial tier available). Pick a voice in their library and
# put its id here; browse models too (eleven_multilingual_v2 = stable quality,
# eleven_v3 = most expressive).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=          # optional; defaults to "Brian" (warm male narrator)
ELEVENLABS_MODEL=             # optional; defaults to eleven_multilingual_v2

# TTS — fallback backend: OpenAI (echo voice, plain). Used when no ElevenLabs
# key is set. Only needed if you want the fallback to work.
OPENAI_API_KEY=
